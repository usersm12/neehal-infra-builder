                    url: wc_add_to_cart_params.ajax_url,
                    data: {
                        'action': 'item_added',
                        'id'    : $pid
                    },
                    success: function (response) {
                        $('.cms-widget-cart-wrap').addClass('open');
                    }
                });
            });
        });
