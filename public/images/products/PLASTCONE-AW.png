    <style>
    .redwop-certificates-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        padding: 20px;
    }
    .redwop-certificate-card {
        background: #fff;
        border: 1px solid #ddd;
        padding: 15px;
        text-align: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        border-radius: 8px;
        transition: transform 0.3s;
    }
    .redwop-certificate-card img {
        max-width: 100%;
        height: auto;
        margin-bottom: 10px;
    }
    .redwop-certificate-card h3 {
        font-size: 16px;
        color: #333;
        margin: 0;
    }
    .redwop-certificate-card:hover {
        transform: translateY(-5px);
    }
    </style>
